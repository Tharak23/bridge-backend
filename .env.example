# Copy to .env in this folder (bridge-backend-supa). Real env vars override these.
# Pairs with bridge-full-stack: same Clerk instance — VITE_CLERK_PUBLISHABLE_KEY must match JWKS host.
# Required for stable local runs (avoids stale CLERK_JWKS_URI / Spring env in IDE pointing at an old Clerk app)
CLERK_JWKS_URI=https://concrete-kit-81.clerk.accounts.dev/.well-known/jwks.json

# Supabase → Project Settings → Database → Database password (for pooler/session mode)
SUPABASE_DB_PASSWORD=

# CORS: default SecurityConfig already allows http://localhost:5173 (Vite).
# Add production frontends comma-separated if needed.
ALLOWED_ORIGINS=http://localhost:5173
