# Copy to .env and adjust. Used when running: set -a && source .env && ./mvnw spring-boot:run
# Install MySQL, create DB + user, run mysql_schema.sql — see MYSQL_SETUP.md

ALLOWED_ORIGINS=http://localhost:5173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=bridge
MYSQL_USER=bridge
MYSQL_PASSWORD=tharak23
MYSQL_USE_SSL=false

# Production (Render + managed MySQL): set host/user/password from your provider; often MYSQL_USE_SSL=true

# Optional admin analytics API (match VITE_BRIDGE_ADMIN_KEY in bridge-full-stack)
# BRIDGE_ADMIN_KEY=your-secret-key
BRIDGE_ADMIN_KEY=tharak23